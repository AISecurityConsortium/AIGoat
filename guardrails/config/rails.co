  "Generate an HTML page"
  "Write JavaScript code"
  "Create a script that"
  "Generate code to"
  "Write a program"
  "Generate SQL query"
  "Write a Python script"
  "Create an exploit"
  "Generate a phishing page"
  "Write malicious code"
  "Create a webpage"
  "Generate HTML with embedded JavaScript"
  "Output an HTML form"
  "Write shell commands"
  "Generate a payload"

define bot refuse code generation
  "I cannot generate code, HTML, scripts, or technical content. I'm here to help with AI Goat Shop products and orders."

define flow check_code_generation
  user request code generation
  bot refuse code generation

# ════════════════════════════════════════════════
# OUTPUT CHECKS (inspect AI response AFTER generation)
# ════════════════════════════════════════════════

define bot refuse pii output
  "I've detected that my response may contain sensitive information. I can help you with product and order inquiries instead."

define flow check_pii_output
  bot ...
  $contains_pii = execute check_output_pii(bot_response=$last_bot_message)
  if $contains_pii
    bot refuse pii output

define flow check_system_prompt_leak
  bot ...
  $has_leak = execute check_system_prompt_leak(bot_response=$last_bot_message)
  if $has_leak
    bot refuse sensitive request

define flow check_hallucination
  bot ...
  $is_off_topic = execute check_off_topic(bot_response=$last_bot_message)
  if $is_off_topic
    bot "I should stay focused on AI Goat Shop topics. How can I help you with our products or orders?"

define flow check_html_output
  bot ...
  $has_html = execute check_html_injection(bot_response=$last_bot_message)
  if $has_html
    bot "I can only provide text-based responses about AI Goat Shop products and orders."
